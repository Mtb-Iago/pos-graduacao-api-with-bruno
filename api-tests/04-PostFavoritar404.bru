meta {
  name: Favoritar Inexistente
  type: http
  seq: 3
}

post {
  url: http://localhost:8000/favoritos/999
  body: none
}

tests {
  test("Deve retornar erro 404 ou 500", function() {
    expect([404, 500]).to.include(res.getStatus());
  });

  test("Deve retornar mensagem de erro específica", function() {
    expect(res.getBody()).to.contain("não encontrado");
  });
}
